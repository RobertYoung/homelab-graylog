tls:
  certificates:
    - certFile: /certs/{{ graylog_service_domain }}.crt
      keyFile: /certs/{{ graylog_service_domain }}.pem
  options:
    default:
      minVersion: VersionTLS12
      sniStrict: true
    syslog-mtls:
      minVersion: VersionTLS12
      sniStrict: true
      clientAuth:
        caFiles:
          - /certs/iamrobertyoung_root_ca.crt
        clientAuthType: RequireAndVerifyClientCert
